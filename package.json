{
  "name": "playwright-test-automation-portfolio",
  "version": "1.0.0",
  "description": "Enterprise-grade test automation framework with Playwright, TypeScript, POM, and BDD",
  "main": "index.js",
  "scripts": {
    "test": "npx playwright test",
    "test:headed": "npx playwright test --headed",
    "test:ui": "npx playwright test --ui",
    "report": "npx playwright show-report",
    "report:allure:generate": "npx allure generate allure-results --clean -o allure-report",
    "report:allure:open": "npx allure open allure-report",
    "report:allure": "npm run report:allure:generate && npm run report:allure:open"
  },
  "keywords": ["playwright", "automation", "typescript", "testing", "pom", "bdd"],
  "author": "Your Name",
  "license": "MIT",
  "devDependencies": {
    "@cucumber/cucumber": "^12.7.0",
    "@playwright/test": "^1.58.2",
    "allure-playwright": "^2.9.0",
    "allure-commandline": "^2.30.0",
    "typescript": "^5.4.5",
    "ts-node": "^10.9.2"
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "exceljs": "^4.4.0"
  }
}

